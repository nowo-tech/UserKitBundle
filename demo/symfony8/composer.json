{
    "name": "nowo-tech/user-kit-demo-symfony8",
    "description": "Demo for User Kit Bundle - Symfony 8",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "nowo-tech/user-kit-bundle": "@dev",
        "doctrine/doctrine-bundle": "^3.0",
        "doctrine/orm": "^3.0",
        "symfony/console": "^8.0",
        "symfony/dotenv": "^8.0",
        "symfony/flex": "^2.0",
        "symfony/form": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/runtime": "^8.0",
        "symfony/security-bundle": "^8.0",
        "symfony/translation": "^8.0",
        "symfony/twig-bundle": "^8.0",
        "symfony/validator": "^8.0",
        "symfony/yaml": "^8.0"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": ["@auto-scripts"],
        "post-update-cmd": ["@auto-scripts"],
        "test": "phpunit --colors=always",
        "test-coverage": "@composer test"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.1.*"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "/var/user-kit-bundle"
        }
    ],
    "require-dev": {
        "nowo-tech/twig-inspector-bundle": "*",
        "phpunit/phpunit": "^11.0",
        "symfony/browser-kit": "^8.0",
        "symfony/css-selector": "^8.0",
        "symfony/debug-bundle": "^8.0",
        "symfony/var-dumper": "^8.0",
        "symfony/web-profiler-bundle": "^8.0"
    }
}
